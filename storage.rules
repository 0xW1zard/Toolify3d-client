rules_version = '2';

// Firebase Storage rules for Toolify 3D custom print orders.
// Users authenticate via a Firebase custom token issued by the Express API
// (Better Auth session → JWT → GET /api/v1/auth/firebase-token).

service firebase.storage {
  match /b/{bucket}/o {
    match /custom-orders/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 50 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
